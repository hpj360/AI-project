# ============================================================
# AI 项目 - 环境变量模板
# 复制此文件为 .env 并填入你的值
# 绝对不要将 .env 提交到版本控制
# ============================================================

# --- OpenClaw 网关 ---
OPENCLAW_LLM_API_KEY=             # LLM 提供商 API 密钥（Anthropic/OpenAI）
OPENCLAW_GATEWAY_PORT=18789       # 网关 WebSocket 端口

# --- DevTeam Slack 集成 ---
SLACK_BOT_TOKEN=xoxb-...          # Slack Bot OAuth 令牌
SLACK_APP_TOKEN=xapp-...          # Slack 应用级令牌（用于 Socket 模式）

# --- DevTeam LLM 模型 ---
OPENCLAW_MODEL_PRIMARY=anthropic/claude-sonnet-4-5
OPENCLAW_MODEL_FALLBACK=openai/gpt-4o

# --- Skillhub ---
SKILLHUB_API_BASE=https://lightmake.site
SKILLHUB_COS_BUCKET=skills-store-1259584892
SKILLHUB_COS_REGION=ap-guangzhou

# --- Tailscale（可选）---
TAILSCALE_AUTH_KEY=               # Tailscale 认证密钥，用于远程访问

# --- GitHub 集成（可选）---
GITHUB_TOKEN=                     # GitHub 个人访问令牌

# --- Notion 集成（可选）---
NOTION_API_KEY=                   # Notion 集成 API 密钥

# --- Trello 集成（可选）---
TRELLO_API_KEY=                   # Trello API 密钥
TRELLO_API_TOKEN=                 # Trello API 令牌
