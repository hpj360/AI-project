# ============================================
# ContentTeam 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 必须配置 ---

# 飞书 Bot Token (ContentTeam 通信渠道)
# 获取方式: https://open.feishu.cn/ 创建应用 -> 凭证与基础信息
FEISHU_BOT_TOKEN=

# Notion API Key (文档管理, 所有角色使用)
# 获取方式: https://notion.so/my-integrations 创建集成
# 格式: ntn_ 或 secret_ 开头
NOTION_API_KEY=

# Trello API Key + Token (任务看板, 所有角色使用)
# 获取方式: https://trello.com/app-key
TRELLO_API_KEY=
TRELLO_TOKEN=

# Anthropic API Key (主模型 Claude Sonnet 4.5)
# 获取方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- 可选配置 ---

# OpenAI API Key (designer 主模型 GPT-4o + 图片生成)
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini API Key (向量搜索, memory search)
# 获取方式: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GitHub Token (director 跨团队协作)
# 获取方式: https://github.com/settings/tokens
GITHUB_TOKEN=
